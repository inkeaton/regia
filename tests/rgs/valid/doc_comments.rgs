# @NAME: Main quest
# @MEANING: The primary narrative
STORY quest PRIORITY 1.
    # @NAME: Finish event
    EVENT done ENVIRONMENT.
    ACTION complete.
    # @NAME: Active phase
    PHASE active.
    PHASE finished.
    # @NAME: Hero agent
    AGENT Hero:
        # @NAME: Completion plan
        DURING active:
            WHEN done ENVIRONMENT:
                DO complete,
                ENTER finished.
