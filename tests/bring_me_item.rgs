# @NAME: Bring Me Item — With Transitions
# @MEANING: Full bring me item quest with explicit phase transitions.
#           The director agent handles all phase changes.

STORY DEFAULT.

    DURING ALWAYS:
        AGENT Citizen:
            ACTION go_about_day.
            EVENT daily_routine MYSELF.
            WHEN daily_routine MYSELF:
                DO go_about_day.

        AGENT Player:
            ACTION explore.
            EVENT bored MYSELF.
            WHEN bored MYSELF:
                DO explore.

STORY bring_me_item PRIORITY 1.

    ACTION thank_player.
    ACTION find_someone_else.
    ACTION express_disappointment.
    ACTION acknowledge.
    ACTION note_citizen_gone.
    ACTION explore.

    EVENT player_accepts   PLAYER.
    EVENT player_rejects   PLAYER.
    EVENT item_delivered   ENVIRONMENT.
    EVENT quest_timed_out  TIMER.
    EVENT citizen_dies     ENVIRONMENT.
    EVENT citizen_missing  ENVIRONMENT.
    EVENT daily_routine    MYSELF.
    EVENT bored            MYSELF.

    CONDITION player_has_item  ENVIRONMENT.
    CONDITION citizen_is_known MYSELF.

    PHASE asking.
    PHASE searching.
    PHASE delivered.
    PHASE failed.

    # ── ASKING phase ───────────────────────────────────────────────
    DURING asking:

        # @NAME: Transitions from asking
        TRANSITION TO searching WHEN player_accepts  PLAYER      IF citizen_is_known MYSELF.
        TRANSITION TO failed    WHEN player_rejects  PLAYER.
        TRANSITION TO failed    WHEN citizen_dies    ENVIRONMENT.
        TRANSITION TO failed    WHEN citizen_missing ENVIRONMENT.

        AGENT Citizen:
            WHEN player_accepts PLAYER IF citizen_is_known MYSELF:
                DO acknowledge.
            WHEN player_rejects PLAYER:
                DO find_someone_else.
            WHEN citizen_dies    ENVIRONMENT:
                DO express_disappointment.
            WHEN citizen_missing ENVIRONMENT:
                DO express_disappointment.

        AGENT Player:
            CONDITION is_busy MYSELF.
            WHEN player_accepts PLAYER IF NOT is_busy MYSELF:
                DO acknowledge.
            WHEN player_rejects PLAYER:
                DO explore.
            WHEN citizen_dies    ENVIRONMENT:
                DO note_citizen_gone.
            WHEN citizen_missing ENVIRONMENT:
                DO note_citizen_gone.

    # ── SEARCHING phase ────────────────────────────────────────────
    DURING searching:

        TRANSITION TO delivered WHEN item_delivered  ENVIRONMENT IF player_has_item ENVIRONMENT.
        TRANSITION TO failed    WHEN quest_timed_out TIMER.
        TRANSITION TO failed    WHEN citizen_dies    ENVIRONMENT.
        TRANSITION TO failed    WHEN citizen_missing ENVIRONMENT.

        AGENT Citizen:
            WHEN item_delivered ENVIRONMENT IF player_has_item ENVIRONMENT:
                DO thank_player.
            WHEN item_delivered ENVIRONMENT IF NOT player_has_item ENVIRONMENT:
                DO express_disappointment.
            WHEN quest_timed_out TIMER:
                DO express_disappointment.
            WHEN citizen_dies    ENVIRONMENT:
                DO express_disappointment.

        AGENT Player:
            WHEN item_delivered  ENVIRONMENT IF player_has_item ENVIRONMENT:
                DO acknowledge.
            WHEN quest_timed_out TIMER:
                DO express_disappointment.
            WHEN citizen_dies    ENVIRONMENT:
                DO note_citizen_gone.
            WHEN citizen_missing ENVIRONMENT:
                DO note_citizen_gone.

    # ── DELIVERED phase ────────────────────────────────────────────
    DURING delivered:

        TRANSITION TO END WHEN daily_routine MYSELF.

        AGENT Citizen:
            WHEN daily_routine MYSELF:
                DO thank_player.

        AGENT Player:
            WHEN bored MYSELF:
                DO explore.

    # ── FAILED phase ───────────────────────────────────────────────
    DURING failed:

        TRANSITION TO END WHEN daily_routine MYSELF.

        AGENT Citizen:
            WHEN daily_routine MYSELF:
                DO express_disappointment.

        AGENT Player:
            WHEN bored MYSELF:
                DO explore.

    # ── ALWAYS active within story ─────────────────────────────────
    DURING ALWAYS:

        AGENT Citizen:
            WHEN citizen_dies    ENVIRONMENT:
                DO express_disappointment.
            WHEN citizen_missing ENVIRONMENT:
                DO express_disappointment.

        AGENT Player:
            WHEN citizen_dies    ENVIRONMENT:
                DO note_citizen_gone.
            WHEN citizen_missing ENVIRONMENT:
                DO note_citizen_gone.