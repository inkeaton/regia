# @NAME: The watcher
# @MEANING: Observes and reacts to the environment

STORY  alert   PRIORITY 2.
STORY  patrol  PRIORITY 1.

ACTION run.
ACTION dance.
ACTION hide.
ACTION scan.

EVENT  spotted ENVIRONMENT.
EVENT  order   DIRECTOR.
EVENT  lost    ENVIRONMENT.

CONDITION is_tired  MYSELF.
CONDITION is_armed  MYSELF.
CONDITION door_open ENVIRONMENT.

# Always-active fallback behaviour
DURING ALWAYS:
    WHEN spotted ENVIRONMENT IF NOT is_tired MYSELF:
        DO run.
    WHEN order DIRECTOR:
        DO dance.

# Alert story — higher priority
DURING alert:
    WHEN spotted ENVIRONMENT IF is_armed MYSELF AND NOT is_tired MYSELF:
        DO run,
        DO hide.
    WHEN spotted ENVIRONMENT IF (is_tired MYSELF OR door_open ENVIRONMENT) AND NOT is_armed MYSELF:
        DO hide.
    WHEN lost ENVIRONMENT:
        DO FORGET is_armed,
        DO BELIEVE is_tired.

# Patrol story — lower priority
DURING patrol:
    WHEN spotted ENVIRONMENT IF is_armed MYSELF OR is_tired MYSELF:
        DO hide.
    WHEN order DIRECTOR IF NOT (is_tired MYSELF AND is_armed MYSELF):
        DO scan.