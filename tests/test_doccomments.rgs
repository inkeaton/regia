# @NAME: The main quest
# @MEANING: Needs to be done to end the game
STORY quest PRIORITY 3.

# This is a plain comment, it will be ignored
ACTION run.

# @NAME: Enemy spotted
# @MEANING: Triggered when an enemy enters the agent's view
EVENT spotted ENVIRONMENT.

CONDITION is_tired MYSELF.

# @NAME: Quest behaviour
# @MEANING: Defines how the agent behaves during the main quest
DURING quest:

    # @NAME: Respond to sighting
    # @MEANING: Agent runs when spotting an enemy unless tired
    WHEN spotted ENVIRONMENT IF NOT is_tired MYSELF:
        DO run.