{
    "comments": {
        "lineComment": "#"
    },
    "brackets": [
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "(", "close": ")" }
    ],
    "surroundingPairs": [
        ["(", ")"]
    ],
    "indentationRules": {
        "increaseIndentPattern": ":[ \\t]*$",
        "decreaseIndentPattern": "^\\s*$"
    },
    "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}